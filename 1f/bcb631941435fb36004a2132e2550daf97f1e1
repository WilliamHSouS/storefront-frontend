identical messages\" FAILS — currently adds all 3.\n\n- [ ] **Step 3: Implement deduplication in `src/stores/toast.ts`**\n\nReplace the full file content:\n\n```typescript\nimport { atom } from 'nanostores';\n\nexport interface Toast {\n  id: string;\n  message: string;\n  type: 'error' | 'success';\n}\n\nexport const $toasts = atom<Toast[]>([]);\n\nconst MAX_VISIBLE = 3;\nconst DEDUP_WINDOW_MS = 2000;\n\n/** Track recent messages for deduplication: message → timestamp */\nconst recentMessages = new Map<string, number>();\n\nexport function showToast(message: string, type: 'error' | 'success' = 'error') {\n  const now = Date.now();\n  const lastShown = recentMessages.get(message);\n  if (lastShown !== undefined && now - lastShown < DEDUP_WINDOW_MS) {\n    return; // Suppress duplicate within window\n  }\n  recentMessages.set(message, now);\n\n  const id = crypto.randomUUID();\n  const next = [...$toasts.get(), { id, message, type }];\n  $toasts.set(next.length > MAX_VISIBLE ? next.slice(-MAX_VISIBLE) : next);\n  setTimeout(() => dismissToast(id), type === 'error' ? 8000 : 4000);\n}\n\nexport function dismissToast(id: string) {\n  $toasts.set($toasts.get().filter((t) => t.id !== id));\n}\n```\n\n- [ ] **Step 4: Run tests to verify they pass**\n\nRun: `pnpm test -- src/stores/toast.test.ts`\nExpected: All tests PASS (existing + 3 new).\n\n- [ ] **Step 5: Commit**\n\n```bash\ngit add src/stores/toast.ts src/stores/toast.test.ts\ngit commit -m \"feat: add toast message deduplication within 2s window\"\n```\n\n---\n\n## Task 4: Create Preact Error Boundary Component\n\n**Files:**\n- Create: `src/components/interactive/ErrorBoundary.tsx`\n- Create: `src/components/interactive/ErrorBoundary.test.tsx`\n\n- [ ] **Step 1: Write the failing test for ErrorBoundary**\n\nCreate `src/components/interactive/ErrorBoundary.test.tsx`:\n\n```tsx\nimport { describe, it, expect, vi, beforeEach } from 'vitest';\nimport { render, fireEvent } from '@testing-library/preact';\nimport { ErrorBoundary } from './ErrorBoundary';\nimport { h } from 'preact';\n\nfunction ThrowingChild({ shouldThrow }: { shouldThrow: boolean }) {\n  if (shouldThrow) throw new Error('Render explosion');\n  return <div data-testid=\"child\">OK</div>;\n}\n\ndescribe('ErrorBoundary', () => {\n  beforeEach(() => {\n    vi.spyOn(console, 'error').mockImplementation(() => {});\n  });\n\n  it('renders children when no error', () => {\n    const { getByTestId } = render(\n      <ErrorBoundary name=\"test\">\n        <ThrowingChild shouldThrow={false} />\n      </ErrorBoundary>,\n    );\n    expect(getByTestId('child').textContent).toBe('OK');\n  });\n\n  it('renders fallback UI when child throws', () => {\n    const { getByText } = render(\n      <ErrorBoundary name=\"test\">\n        <ThrowingChild shouldThrow={true} />\n      </ErrorBoundary>,\n    );\n    expect(getByText('Something went wrong')).toBeTruthy();\n  });\n\n  it('calls onError callback when child throws', () => {\n    const onError = vi.fn();\n    render(\n      <ErrorBoundary name=\"test\" onError={onError}>\n        <ThrowingChild shouldThrow={true} />\n      </ErrorBoundary>,\n    );\n    expect(onError).toHaveBeenCalledWith(expect.any(Error), 'test');\n  });\n\n  it('recovers after retry button is clicked', async () => {\n    // We can't dynamically change shouldThrow, so we test that retry resets state\n    let throwCount = 0;\n    function ConditionalThrow() {\n      throwCount++;\n      if (throwCount <= 1) throw new Error('First render fails');\n      return <div data-testid=\"recovered\">Recovered</div>;\n    }\n\n    const { getByRole, getByTestId } = render(\n      <ErrorBoundary name=\"test\">\n        <ConditionalThrow />\n      </ErrorBoundary>,\n    );\n\n    // Should show fallback after first throw\n    const retryBtn = getByRole('button', { name: /try again/i });\n    expect(retryBtn).toBeTruthy();\n\n    // Click retry — second render succeeds\n    fireEvent.click(retryBtn);\n    expect(getByTestId('r