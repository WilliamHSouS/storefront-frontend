ned', () => {\n    expect(errorCode(null)).toBeUndefined();\n    expect(errorCode(undefined)).toBeUndefined();\n  });\n\n  it('returns undefined when no code field exists', () => {\n    expect(errorCode({ message: 'Something failed' })).toBeUndefined();\n  });\n});\n```\n\n- [ ] **Step 2: Run tests to verify they fail**\n\nRun: `pnpm test -- src/lib/errors.test.ts`\nExpected: FAIL — module `./errors` does not exist.\n\n- [ ] **Step 3: Implement `src/lib/errors.ts`**\n\nThis is the superset of both `cart.ts` and `checkout-actions.ts` error extraction, unified:\n\n```typescript\n/**\n * Unified error detail extraction for all API error envelopes.\n *\n * Handles: SDK ApiError (body.detail, body.error.message), DRF errors (detail),\n * validation errors (body.error.details field map), raw Error objects,\n * and status/statusText fallbacks.\n */\nexport function errorDetail(error: unknown): string {\n  if (!error || typeof error !== 'object') return 'Unknown error';\n  const e = error as Record<string, unknown>;\n\n  // SDK ApiError wraps the response body\n  if (e.body && typeof e.body === 'object') {\n    const body = e.body as Record<string, unknown>;\n\n    // Nested error envelope: body.error.{ code, message, details }\n    if (body.error && typeof body.error === 'object') {\n      const err = body.error as Record<string, unknown>;\n\n      // VALIDATION_ERROR: format field-level details\n      if (err.code === 'VALIDATION_ERROR' && err.details && typeof err.details === 'object') {\n        const details = err.details as Record<string, string[]>;\n        const messages = Object.entries(details).map(([field, fieldErrors]) => {\n          const fieldName = field.replace(/_/g, ' ');\n          const errorMsg = Array.isArray(fieldErrors) ? fieldErrors.join(', ') : String(fieldErrors);\n          return `${fieldName}: ${errorMsg}`;\n        });\n        if (messages.length > 0) return messages.join('. ');\n      }\n\n      if (typeof err.message === 'string') return err.message;\n    }\n\n    if (typeof body.message === 'string') return body.message;\n    if (typeof body.detail === 'string') return body.detail;\n  }\n\n  // Raw DRF-style: { detail: \"...\" }\n  if (typeof e.detail === 'string') return e.detail;\n\n  // Raw error envelope: { error: { code, message } }\n  if (e.error && typeof e.error === 'object') {\n    const nested = e.error as Record<string, unknown>;\n    if (typeof nested.message === 'string') return nested.message;\n  }\n\n  // Standard Error objects\n  if ('message' in error && typeof (error as Error).message === 'string')\n    return (error as Error).message;\n\n  // Status + statusText fallback\n  if (typeof e.status === 'number' && typeof e.statusText === 'string') {\n    return `${e.status} ${e.statusText}`;\n  }\n\n  return 'Unknown error';\n}\n\n/** Extract the `code` field from a backend error envelope, if present. */\nexport function errorCode(error: unknown): string | undefined {\n  if (!error || typeof error !== 'object') return undefined;\n  const e = error as Record<string, unknown>;\n\n  // SDK ApiError: body.error.code\n  if (e.body && typeof e.body === 'object') {\n    const body = e.body as Record<string, unknown>;\n    if (body.error && typeof body.error === 'object') {\n      const nested = body.error as Record<string, unknown>;\n      if (typeof nested.code === 'string') return nested.code;\n    }\n  }\n\n  // Raw envelope: error.code\n  if (e.error && typeof e.error === 'object') {\n    const nested = e.error as Record<string, unknown>;\n    if (typeof nested.code === 'string') return nested.code;\n  }\n\n  return undefined;\n}\n```\n\n- [ ] **Step 4: Run tests to verify they pass**\n\nRun: `pnpm test -- src/lib/errors.test.ts`\nExpected: All 12 tests PASS.\n\n- [ ] **Step 5: Update `src/stores/cart.ts` — remove `errorDetail` and `errorCode`, re-export from `@/lib/errors`**\n\nRemove lines 106–154 (the `errorDetail` and `errorCode` function bodies). Replace with re-exports:\n\n```typescr