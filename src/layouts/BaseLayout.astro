---
import { themeToCSS } from '@/lib/theme';
import type { MerchantConfig } from '@/types/merchant';
import { getMessages } from '@/i18n';
import { setSSRMessages } from '@/i18n/client';
import '@/styles/global.css';

// Shared interactive islands — available on every page
import CartBar from '@/components/interactive/CartBar';
import CartDrawer from '@/components/interactive/CartDrawer';
import ProductDetail from '@/components/interactive/ProductDetail';
import SearchBar from '@/components/interactive/SearchBar';
import Toast from '@/components/interactive/Toast';
import MerchantComms from '@/components/interactive/MerchantComms';
import { FulfillmentOverlay } from '@/components/interactive/FulfillmentOverlay';
import { DeliveryBanner } from '@/components/interactive/DeliveryBanner';
import type { CommsMessage, CommsTheme } from '@/stores/comms';
import { BANNER_THEME_CLASSES } from '@/lib/comms-theme';
import { safeUrl } from '@/lib/safe-url';

interface Props {
  title: string;
  description?: string;
  hideSharedIslands?: boolean;
}

const { title, description, hideSharedIslands = false } = Astro.props;
const merchant = Astro.locals.merchant as MerchantConfig | undefined;
const lang = Astro.locals.lang as string | undefined;
const themeCSS = merchant ? themeToCSS(merchant.theme) : '';
// hmacSecret is included client-side — it's a vendor-specific HMAC key (not a user secret)
// needed for client-side write requests (add to cart, checkout mutations) to pass backend signature validation
const merchantJSON = merchant ? JSON.stringify(merchant) : '';
const messages = lang ? getMessages(lang) : null;
const messagesJSON = messages ? JSON.stringify(messages) : '';

// Populate the client i18n module's SSR store so Preact islands render
// with real translations instead of raw message keys. Without this,
// attributes like aria-label would contain keys (e.g. "enterPostcode")
// and Preact's hydration won't update them, causing E2E mismatches.
if (messages) setSSRMessages(messages);

// Build Google Fonts URL from merchant theme fonts
const fontFamilies = new Set<string>();
if (merchant?.theme.fontHeading) fontFamilies.add(merchant.theme.fontHeading);
if (merchant?.theme.fontBody) fontFamilies.add(merchant.theme.fontBody);
const googleFontsUrl =
  fontFamilies.size > 0
    ? `https://fonts.googleapis.com/css2?${[...fontFamilies].map((f) => `family=${f.replace(/ /g, '+')}:wght@400;500;600;700`).join('&')}&display=swap`
    : null;
const langValue = lang ?? 'en';

// Extract first top_banner content for SSR to prevent CLS
let ssrTopBanner: {
  headline: string;
  body: string;
  cta_label: string;
  cta_url: string;
  theme: CommsTheme;
  custom_colors: Record<string, string>;
} | null = null;

let commsMessages: CommsMessage[] = [];
{
  const sdk = Astro.locals.sdk;
  if (sdk) {
    try {
      // eslint-disable-next-line @typescript-eslint/no-explicit-any -- merchant-comms endpoint not in SDK
      const { data } = await sdk.GET('/api/v1/merchant-comms/storefront/active/' as any);
      if (data) {
        commsMessages = Array.isArray(data)
          ? (data as unknown as CommsMessage[])
          : (((data as unknown as Record<string, unknown>).results as CommsMessage[]) ?? []);
      }
    } catch {
      // Silent degradation — no banners is better than a broken page
    }
  }
}

// Find the first top_banner content for SSR rendering
for (const msg of commsMessages) {
  for (const content of msg.contents) {
    if (content.surface === 'top_banner') {
      ssrTopBanner = content;
      break;
    }
  }
  if (ssrTopBanner) break;
}
---

<!doctype html>
<html lang={lang ?? 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {merchant?.favicon && <link rel="icon" href={merchant.favicon} />}
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href={import.meta.env.PUBLIC_API_BASE_URL} />
    {googleFontsUrl && <link rel="preconnect" href="https://fonts.googleapis.com" />}
    {googleFontsUrl && <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />}
    {googleFontsUrl && <link rel="stylesheet" href={googleFontsUrl} />}
    {themeCSS && <style set:html={`:root { ${themeCSS} }`} />}
    {/* PostHog queue stub — events pushed before SDK loads are replayed on init */}
    <script is:inline>
      /* eslint-disable @typescript-eslint/no-unused-expressions, prefer-rest-params */
      !(function () {
        const p = (window.posthog = window.posthog || []);
        if (!p.__loaded) {
          p._i = [];
          p.init = function (k, o) {
            p._i.push([k, o]);
          };
          p.capture = function () {
            p.push(Array.prototype.slice.call(arguments));
          };
          p.identify = function () {
            p.push(['$identify'].concat(Array.prototype.slice.call(arguments)));
          };
        }
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    {
      merchantJSON && (
        <script define:vars={{ merchantJSON, langValue, messagesJSON }}>
          window.__MERCHANT__ = Object.freeze(JSON.parse(merchantJSON)); window.__LANG__ =
          langValue; if (messagesJSON) window.__MESSAGES__ = JSON.parse(messagesJSON);
        </script>
      )
    }
    {
      /* SSR top banner — prevents CLS by reserving space before island hydration.
         Inline script checks localStorage for dismissals to prevent flash-then-hide. */
    }
    {
      ssrTopBanner && !hideSharedIslands && (
        <>
          <div
            data-ssr-top-banner
            role="status"
            class={`sticky top-0 z-30 w-full px-4 py-3 ${BANNER_THEME_CLASSES[ssrTopBanner.theme]}`}
          >
            <div class="mx-auto flex max-w-5xl items-center justify-between gap-3">
              <div class="flex flex-1 flex-wrap items-center gap-x-3 gap-y-1">
                {ssrTopBanner.headline && <span class="font-medium">{ssrTopBanner.headline}</span>}
                {ssrTopBanner.body && <span class="opacity-90">{ssrTopBanner.body}</span>}
                {ssrTopBanner.cta_label && ssrTopBanner.cta_url && (
                  <a
                    href={safeUrl(ssrTopBanner.cta_url)}
                    class="underline underline-offset-2 font-medium"
                  >
                    {ssrTopBanner.cta_label}
                  </a>
                )}
              </div>
            </div>
          </div>
        </>
      )
    }
    {
      /* Hide SSR banner if user previously dismissed comms — runs outside the conditional
         so the Astro prettier plugin can parse it (script-in-fragment is unsupported). */
    }
    <script is:inline>
      try {
        if (
          Object.keys(JSON.parse(localStorage.getItem('sous:comms:dismissed') || '{}')).length > 0
        ) {
          const el = document.querySelector('[data-ssr-top-banner]');
          if (el) el.style.display = 'none';
        }
      } catch {
        /* best-effort */
      }
    </script>
    {!hideSharedIslands && <MerchantComms client:idle lang={langValue} messages={commsMessages} />}
    {!hideSharedIslands && <DeliveryBanner client:idle lang={langValue} />}

    <slot />

    {/* Shared islands: cart, product detail modal, search */}
    <CartBar client:idle lang={langValue} />
    {!hideSharedIslands && <CartDrawer client:idle lang={langValue} />}
    {!hideSharedIslands && <ProductDetail client:idle lang={langValue} />}
    <SearchBar client:idle lang={langValue} />
    <Toast client:idle lang={langValue} />
    <FulfillmentOverlay client:idle lang={langValue} />

    <script is:inline>
      document.addEventListener('click', function (e) {
        if (!e.target || typeof e.target.closest !== 'function') return;
        const link = e.target.closest('[data-product-modal]');
        if (!link) return;
        const id = link.getAttribute('data-product-id');
        const name = link.getAttribute('data-product-name');
        if (!id || !name) return;
        e.preventDefault();
        window.dispatchEvent(
          new CustomEvent('open-product', {
            detail: {
              id: id,
              name: name,
              slug: link.getAttribute('data-product-slug'),
            },
          }),
        );
      });
    </script>

    <script>
      function boot() {
        import('@/analytics').then(({ initAnalytics }) =>
          initAnalytics().catch((err) => {
            console.error('[analytics] initialization failed:', err);
          }),
        );
      }
      if ('requestIdleCallback' in window) {
        requestIdleCallback(boot);
      } else {
        setTimeout(boot, 3000);
      }
    </script>
  </body>
</html>
