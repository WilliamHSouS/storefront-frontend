---
import type { MerchantConfig } from '@/types/merchant';
import { getMerchantDescription } from '@/types/merchant';
import { t } from '@/i18n';

interface Props {
  merchant: MerchantConfig;
  lang: string;
}

const { merchant, lang } = Astro.props;
const description = getMerchantDescription(merchant, lang);
const socialEntries = Object.entries(merchant.social);

// Fetch CMS pages from API for footer links
const sdk = Astro.locals.sdk;
let pages: Array<{ slug: string; title: string }> = [];
try {
  const { data } = await sdk.GET('/api/v1/pages/');
  pages = (data as { results?: Array<{ slug: string; title: string }> })?.results ?? [];
} catch {
  /* endpoint may not exist yet */
}

/** Extract display hostname from a full URL (e.g. "https://brasserievandam.nl" → "brasserievandam.nl"). */
function displayHost(url: string): string {
  try {
    return new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return url;
  }
}
---

<footer class="border-t border-border bg-muted/50 px-4 py-8">
  <div class="mx-auto grid max-w-screen-xl gap-8 sm:grid-cols-2 lg:grid-cols-3">
    <div>
      <h3 class="font-heading text-sm font-semibold uppercase tracking-wider text-foreground">
        {merchant.name}
      </h3>
      <p class="mt-2 text-sm text-muted-foreground">{description}</p>
      {
        merchant.website && (
          <a
            href={merchant.website}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-2 inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground"
          >
            {/* Globe icon */}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="shrink-0"
            >
              <>
                <circle cx="12" cy="12" r="10" />
                <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" />
                <path d="M2 12h20" />
              </>
            </svg>
            {displayHost(merchant.website)}
          </a>
        )
      }
      {
        pages.length > 0 && (
          <nav class="mt-3 flex flex-col gap-1" aria-label="Pages">
            {pages.map((page) => (
              <a
                href={`/${lang}/pages/${page.slug}`}
                class="text-sm text-muted-foreground hover:text-foreground"
              >
                {page.title}
              </a>
            ))}
          </nav>
        )
      }
    </div>

    <div>
      <h3 class="font-heading text-sm font-semibold uppercase tracking-wider text-foreground">
        {t('contact', lang)}
      </h3>
      <ul class="mt-2 space-y-1 text-sm text-muted-foreground">
        <li>{merchant.contact.address}</li>
        <li>
          <a
            href={`tel:${merchant.contact.phone.replace(/\s/g, '')}`}
            class="hover:text-foreground"
          >
            {merchant.contact.phone}
          </a>
        </li>
        <li>
          <a href={`mailto:${merchant.contact.email}`} class="hover:text-foreground">
            {merchant.contact.email}
          </a>
        </li>
      </ul>
    </div>

    <div>
      <h3 class="font-heading text-sm font-semibold uppercase tracking-wider text-foreground">
        {t('hours', lang)}
      </h3>
      <ul class="mt-2 space-y-1 text-sm text-muted-foreground">
        {
          merchant.hours.map((h) => (
            <li>
              {h.days}: {h.open} – {h.close}
            </li>
          ))
        }
      </ul>
      {
        socialEntries.length > 0 && (
          <div class="mt-4 flex gap-2">
            {socialEntries.map(([platform, url]) => (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex h-8 w-8 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
                aria-label={platform}
              >
                {platform === 'instagram' ? (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                    <line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
                  </svg>
                ) : platform === 'facebook' ? (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
                  </svg>
                ) : platform === 'twitter' || platform === 'x' ? (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z" />
                  </svg>
                ) : platform === 'tiktok' ? (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5" />
                  </svg>
                ) : (
                  <span class="text-xs font-medium">{platform}</span>
                )}
              </a>
            ))}
          </div>
        )
      }
    </div>
  </div>

  <div
    class="mx-auto mt-8 max-w-screen-xl border-t border-border pt-4 text-center text-xs text-muted-foreground"
  >
    {t('poweredBy', lang)}
    <a
      href={`https://poweredbysous.com?utm_source=storefront&utm_medium=footer&utm_campaign=powered_by&utm_content=${merchant.slug}`}
      class="underline hover:text-foreground"
      target="_blank"
      rel="noopener noreferrer">SOUS</a
    >
  </div>
</footer>
