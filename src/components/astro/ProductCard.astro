---
import { formatPrice, langToLocale } from '@/lib/currency';
import {
  getEffectivePrice,
  getOriginalPrice,
  hasUnitDiscount,
  type PricedItem,
} from '@/lib/pricing';
import { responsiveImage } from '@/lib/image';
import PromoBadge from './PromoBadge.astro';
import PopularBadge from './PopularBadge.astro';
import AddToCartButton from '@/components/interactive/AddToCartButton';
interface Props {
  product: {
    id: number | string;
    slug: string;
    name: string;
    description?: string | null;
    intro?: string | null;
    price: string;
    compare_at_price?: string | null;
    image?: string | null;
    sold_out?: boolean;
    discount?: PricedItem['discount'];
    modifier_groups?: unknown[];
    tags?: string[];
    is_popular?: boolean | null;
  };
  lang: string;
  currency: string;
  variant?: 'grid' | 'list';
}

const { product, lang, currency, variant = 'grid' } = Astro.props;
const locale = langToLocale(lang);
const pricedItem: PricedItem = { price: product.price, discount: product.discount ?? null };
const effectivePrice = getEffectivePrice(pricedItem);
const originalPrice = getOriginalPrice(pricedItem);
const showStrikethrough = hasUnitDiscount(pricedItem);
const hasModifiers = (product.modifier_groups?.length ?? 0) > 0;
const cardDescription = product.description || product.intro || null;
const isGrid = variant === 'grid';
const imgAttrs = product.image
  ? responsiveImage(
      product.image,
      isGrid ? [208, 300, 450, 600] : [104, 208],
      isGrid ? '(min-width: 768px) 300px, 50vw' : '104px',
    )
  : null;
---

<article
  class:list={[
    'group relative cursor-pointer overflow-hidden rounded-[16px] bg-card p-2 sm:pt-2 sm:px-2 sm:pb-1.5',
    isGrid ? 'flex flex-col' : 'flex flex-row',
  ]}
  data-product-id={product.id}
>
  {/* Image */}
  <div
    class:list={[
      'relative shrink-0 overflow-hidden',
      isGrid ? 'aspect-square w-full' : 'h-[104px] w-[104px]',
    ]}
  >
    <div class="absolute inset-0 overflow-hidden rounded-[10px] bg-card-image animate-pulse">
      {
        imgAttrs ? (
          <img
            src={imgAttrs.src}
            srcset={imgAttrs.srcset}
            sizes={imgAttrs.sizes}
            alt={product.name}
            class="h-full w-full object-cover transition-transform group-hover:scale-105"
            loading="lazy"
            width={isGrid ? 300 : 104}
            height={isGrid ? 300 : 104}
            onload="this.parentElement.classList.remove('animate-pulse')"
          />
        ) : (
          <div class="flex h-full w-full items-center justify-center text-muted-foreground/30">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <>
                <rect width="18" height="18" x="3" y="3" rx="2" ry="2" />
                <circle cx="9" cy="9" r="2" />
                <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
              </>
            </svg>
          </div>
        )
      }
    </div>
    {
      product.discount && (
        <PromoBadge item={pricedItem} currency={currency} locale={locale} lang={lang} overlay />
      )
    }
    <PopularBadge isPopular={product.is_popular} tags={product.tags ?? []} lang={lang} overlay />
  </div>
  <span data-fulfillment-badge class="empty:hidden"></span>

  {/* Content */}
  <div
    class:list={[
      'flex flex-1 flex-col justify-between',
      isGrid ? 'gap-2 pt-2 sm:gap-4 sm:px-3 sm:pt-4 sm:pb-3' : 'gap-2 pl-3',
    ]}
  >
    <div>
      <div class="flex items-start justify-between gap-2">
        <h3 class="text-base font-medium leading-tight text-card-foreground sm:text-base">
          <a
            href={`/${lang}/product/${product.slug}`}
            class="after:absolute after:inset-0"
            data-product-modal
            data-product-id={product.id}
            data-product-name={product.name}
            data-product-slug={product.slug}
          >
            {product.name}
          </a>
        </h3>
      </div>
      {
        cardDescription && (
          <p class="mt-0.5 line-clamp-2 text-sm font-normal leading-relaxed text-muted-foreground">
            {cardDescription}
          </p>
        )
      }
    </div>

    <div class="mt-auto flex items-center justify-between gap-2 sm:pb-1">
      <div class="flex items-baseline gap-1.5">
        {
          showStrikethrough && (
            <span class="text-xs font-medium text-muted-foreground line-through sm:text-sm">
              {formatPrice(String(originalPrice), currency, locale)}
            </span>
          )
        }
        <span
          class:list={[
            'text-sm font-medium sm:text-base',
            showStrikethrough ? 'text-destructive' : 'text-card-foreground/70',
          ]}
        >
          {formatPrice(String(effectivePrice), currency, locale)}
        </span>
      </div>

      <div class="relative z-10">
        <AddToCartButton
          client:idle
          productId={String(product.id)}
          productName={product.name}
          productSlug={product.slug}
          hasModifiers={hasModifiers}
          soldOut={product.sold_out ?? false}
          lang={lang}
        />
      </div>
    </div>
  </div>
</article>
