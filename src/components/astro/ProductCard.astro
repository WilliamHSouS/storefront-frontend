---
import { formatPrice, langToLocale } from '@/lib/currency';
import { getEffectivePrice, getOriginalPrice, hasUnitDiscount, type PricedItem } from '@/lib/pricing';
import PromoBadge from './PromoBadge.astro';
import AddToCartButton from '@/components/interactive/AddToCartButton';
import { t } from '@/i18n';

interface Props {
  product: {
    id: number | string;
    slug: string;
    name: string;
    description?: string | null;
    price: string;
    compare_at_price?: string | null;
    image?: string | null;
    sold_out?: boolean;
    discount?: PricedItem['discount'];
    modifier_groups?: unknown[];
  };
  lang: string;
  currency: string;
  variant?: 'grid' | 'list';
}

const { product, lang, currency, variant = 'grid' } = Astro.props;
const locale = langToLocale(lang);
const pricedItem: PricedItem = { price: product.price, discount: product.discount ?? null };
const effectivePrice = getEffectivePrice(pricedItem);
const originalPrice = getOriginalPrice(pricedItem);
const showStrikethrough = hasUnitDiscount(pricedItem);
const hasModifiers = (product.modifier_groups?.length ?? 0) > 0;
const isGrid = variant === 'grid';
---

<article
  class:list={[
    'group relative overflow-hidden rounded-lg border border-border bg-card transition-shadow hover:shadow-md',
    isGrid ? 'flex flex-col' : 'flex flex-row',
  ]}
  data-product-id={product.id}
>
  {/* Image */}
  <div
    class:list={[
      'shrink-0 overflow-hidden bg-card-image',
      isGrid ? 'aspect-square w-full' : 'h-[104px] w-[104px]',
    ]}
  >
    {product.image ? (
      <img
        src={product.image}
        alt={product.name}
        class="h-full w-full object-cover transition-transform group-hover:scale-105"
        loading="lazy"
        width={isGrid ? 300 : 104}
        height={isGrid ? 300 : 104}
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center text-muted-foreground/30">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
      </div>
    )}
  </div>

  {/* Content */}
  <div class="flex flex-1 flex-col justify-between gap-2 p-3">
    <div>
      <div class="flex items-start justify-between gap-2">
        <h3 class="font-heading text-sm font-semibold leading-tight text-card-foreground">
          <a href={`/${lang}/product/${product.slug}`} class="after:absolute after:inset-0">
            {product.name}
          </a>
        </h3>
        {product.discount && (
          <PromoBadge item={pricedItem} currency={currency} locale={locale} />
        )}
      </div>
      {product.description && (
        <p class="mt-1 line-clamp-2 text-xs text-muted-foreground">
          {product.description}
        </p>
      )}
    </div>

    <div class="flex items-center justify-between gap-2">
      <div class="flex items-baseline gap-1.5">
        <span class="text-sm font-semibold text-card-foreground">
          {formatPrice(String(effectivePrice), currency, locale)}
        </span>
        {showStrikethrough && (
          <span class="text-xs text-muted-foreground line-through">
            {formatPrice(String(originalPrice), currency, locale)}
          </span>
        )}
      </div>

      <div class="relative z-10">
        <AddToCartButton
          client:visible
          productId={String(product.id)}
          productName={product.name}
          hasModifiers={hasModifiers}
          soldOut={product.sold_out ?? false}
          lang={lang}
        />
      </div>
    </div>
  </div>
</article>
