---
import { t } from '@/i18n';

interface Props {
  isPopular?: boolean | null;
  isTrending?: boolean | null;
  tags?: string[];
  lang: string;
  overlay?: boolean;
}

const { isPopular: isPopularProp, isTrending, tags = [], lang, overlay = false } = Astro.props;
// Prefer API field, fall back to tag-based detection for merchants without computed stats
const isPopular = isPopularProp ?? tags.some((tag) => tag.toLowerCase() === 'popular');

// Trending takes priority over popular (more specific, time-sensitive signal)
const badge = isTrending
  ? { label: t('trending', lang) }
  : isPopular
    ? { label: t('popular', lang) }
    : null;
---

{
  badge && (
    <span
      class:list={[
        'inline-flex items-center justify-center font-medium leading-none whitespace-nowrap',
        overlay
          ? 'absolute top-2 left-2 z-10 rounded-full bg-white/85 px-2.5 py-1 text-[11px] tracking-wide text-foreground/80 shadow-sm backdrop-blur-sm sm:top-2.5 sm:left-2.5'
          : 'rounded-full bg-foreground/5 px-2 py-0.5 text-[11px] tracking-wide text-foreground/60',
      ]}
    >
      {badge.label}
    </span>
  )
}
