---
import { getDiscountLabel, type PricedItem } from '@/lib/pricing';

interface Props {
  item: PricedItem;
  currency: string;
  locale: string;
}

const { item, currency, locale } = Astro.props;
const label = getDiscountLabel(item, currency, locale);
---

{label && (
  <span class="inline-flex items-center rounded-sm bg-destructive px-1.5 py-0.5 text-xs font-medium text-destructive-foreground">
    {label}
  </span>
)}
