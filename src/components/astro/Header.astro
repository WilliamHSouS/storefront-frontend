---
import type { MerchantConfig } from '@/types/merchant';
import { t } from '@/i18n';
import CartBadge from '@/components/interactive/CartBadge';

interface Props {
  merchant: MerchantConfig;
  lang: string;
}

const { merchant, lang } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-border bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <div class="mx-auto flex h-14 max-w-screen-xl items-center justify-between px-4">
    <a href={`/${lang}/`} class="flex items-center gap-2">
      {merchant.logo && (
        <img
          src={merchant.logo}
          alt={merchant.name}
          class="h-8 w-auto"
          width="32"
          height="32"
        />
      )}
      <span class="font-heading text-lg font-semibold">{merchant.name}</span>
    </a>

    <nav class="flex items-center gap-2">
      <button
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-md text-muted-foreground hover:bg-accent hover:text-accent-foreground"
        aria-label={t('search', lang)}
        data-search-trigger
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </button>

      <CartBadge client:load lang={lang} />
    </nav>
  </div>
</header>
