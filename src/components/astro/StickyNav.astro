---
import type { MerchantConfig } from '@/types/merchant';
import { t } from '@/i18n';
import CategoryTabs from '@/components/interactive/CategoryTabs';
import CartBadge from '@/components/interactive/CartBadge';

interface Props {
  categories: { id: string | number; name: string }[];
  merchant: MerchantConfig;
  lang: string;
}

const { categories, merchant: _merchant, lang } = Astro.props;
---

<div class="sticky top-0 z-30 bg-background pt-2 pb-3 sm:pt-3 sm:pb-4">
  <div class="mx-auto flex max-w-[1160px] items-center gap-3 px-4 sm:px-6 lg:px-8">
    <CategoryTabs client:idle categories={categories} />

    <div class="flex items-center gap-1">
      <button
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-card text-foreground hover:bg-card/80"
        aria-label={t('search', lang)}
        data-search-trigger
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path>
        </svg>
      </button>
      <CartBadge client:load lang={lang} />
    </div>
  </div>
</div>
