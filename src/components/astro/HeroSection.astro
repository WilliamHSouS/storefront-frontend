---
import type { MerchantConfig } from '@/types/merchant';
import { getMerchantDescription } from '@/types/merchant';
import { responsiveImage } from '@/lib/image';

interface Props {
  merchant: MerchantConfig;
  lang: string;
}

const { merchant, lang } = Astro.props;
const description = getMerchantDescription(merchant, lang);
const heroAttrs = merchant.heroImage
  ? responsiveImage(merchant.heroImage, [640, 960, 1280, 1920], '100vw', 80)
  : null;
---

<section class="relative">
  <div class="aspect-[21/9] w-full overflow-hidden bg-card-image sm:aspect-[3/1]">
    {
      heroAttrs ? (
        <img
          src={heroAttrs.src}
          srcset={heroAttrs.srcset}
          sizes={heroAttrs.sizes}
          alt={merchant.name}
          class="h-full w-full object-cover"
          width="1200"
          height="400"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      ) : null
    }
  </div>

  <div class="relative mx-auto -mt-10 max-w-screen-xl px-4">
    <div class="flex items-end gap-4">
      {
        merchant.logo && (
          <div class="flex h-20 w-20 shrink-0 items-center justify-center overflow-hidden rounded-lg border-4 border-background bg-card shadow-md">
            <img
              src={merchant.logo}
              alt=""
              class="h-full w-full object-contain p-2"
              width="80"
              height="80"
              loading="eager"
            />
          </div>
        )
      }
      <div class="pb-1">
        <h1 class="font-heading text-2xl font-bold text-foreground sm:text-3xl">
          {merchant.name}
        </h1>
        <p class="mt-0.5 text-sm text-muted-foreground">
          {description}
        </p>
      </div>
    </div>

    <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-muted-foreground">
      <span class="inline-flex items-center gap-1">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle
            cx="12"
            cy="10"
            r="3"></circle></svg
        >
        {merchant.contact.address}
      </span>
      {
        merchant.hours[0] && (
          <span class="inline-flex items-center gap-1">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <>
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </>
            </svg>
            {merchant.hours[0].open} – {merchant.hours[0].close}
          </span>
        )
      }
    </div>
  </div>
</section>
