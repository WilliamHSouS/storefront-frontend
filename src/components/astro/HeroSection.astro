---
import type { MerchantConfig } from '@/types/merchant';
import { t } from '@/i18n';
import { getMerchantDescription } from '@/types/merchant';
import { responsiveImage } from '@/lib/image';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  merchant: MerchantConfig;
  lang: string;
}

const { merchant, lang } = Astro.props;
const currentPath = Astro.url.pathname;
const description = getMerchantDescription(merchant, lang);
const heroAttrs = merchant.heroImage
  ? responsiveImage(merchant.heroImage, [640, 960, 1280, 1920], '100vw', 80)
  : null;

// Compute "Open until" from current day's hours
const now = new Date();
const dayIndex = now.getDay(); // 0=Sun
const dayAbbrs = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
const todayAbbr = dayAbbrs[dayIndex];
const todayHours = merchant.hours.find((h) => {
  const parts = h.days.split('-');
  if (parts.length === 2) {
    const startIdx = dayAbbrs.indexOf(parts[0]);
    const endIdx = dayAbbrs.indexOf(parts[1]);
    if (startIdx <= endIdx) return dayIndex >= startIdx && dayIndex <= endIdx;
    return dayIndex >= startIdx || dayIndex <= endIdx;
  }
  return h.days.includes(todayAbbr);
});
const closeTime = todayHours?.close ?? null;
---

<section class="relative bg-card">
  {/* Hero image — fixed height */}
  <div class="relative h-40 w-full overflow-hidden sm:h-56">
    {
      heroAttrs ? (
        <img
          src={heroAttrs.src}
          srcset={heroAttrs.srcset}
          sizes={heroAttrs.sizes}
          alt={merchant.name}
          class="h-full w-full object-cover"
          width="1200"
          height="224"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      ) : null
    }
  </div>

  {/* Merchant info — stacked vertically */}
  <div class="relative mx-auto max-w-[1160px] px-4 sm:px-6 lg:px-8">
    {/* Logo card — overlapping the hero image */}
    <div class="-mt-10 sm:-mt-12">
      {
        merchant.logo && (
          <div class="relative h-20 w-20 flex-shrink-0 overflow-hidden rounded-2xl border border-card bg-card shadow-sm sm:h-24 sm:w-24">
            <img
              src={merchant.logo}
              alt=""
              class="h-full w-full rounded-2xl object-contain p-1"
              width="96"
              height="96"
              loading="eager"
            />
          </div>
        )
      }
    </div>

    {/* Name + description */}
    <div class="mt-3">
      <h1 class="text-lg font-bold leading-tight text-foreground sm:text-xl">
        {merchant.name}
      </h1>
      <p class="mt-1 text-[13px] leading-relaxed text-muted-foreground sm:text-sm">
        {description}
      </p>
    </div>

    {/* Meta: location + hours + language */}
    <div class="mt-3 flex items-center gap-4 pb-4 text-muted-foreground sm:pb-5">
      <span class="inline-flex items-center gap-1.5 text-xs sm:text-sm">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
          <circle cx="12" cy="10" r="3"></circle>
        </svg>
        {merchant.contact.address.split(',').pop()?.trim() ?? merchant.contact.address}
      </span>
      {
        closeTime && (
          <span class="flex items-center gap-1.5 text-xs sm:text-sm">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="10" />
              <path d="M12 6v6l4 2" />
            </svg>
            {t('openUntil', lang, { time: closeTime })}
          </span>
        )
      }
      <LanguageSwitcher lang={lang} languages={merchant.languages} currentPath={currentPath} />
    </div>
  </div>
</section>
