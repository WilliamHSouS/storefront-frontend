---
import ProductCard from './ProductCard.astro';

interface Props {
  products: Array<Record<string, unknown>>;
  lang: string;
  currency: string;
}

const { products, lang, currency } = Astro.props;
---

<div class="flex flex-col gap-3">
  {products.map((product) => (
    <ProductCard product={product as any} lang={lang} currency={currency} variant="list" />
  ))}
</div>
