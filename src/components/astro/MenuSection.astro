---
import ProductCard from './ProductCard.astro';
import type { NormalizedProduct } from '@/lib/normalize';

interface Props {
  category: { id: string | number; name: string; slug?: string };
  products: NormalizedProduct[];
  lang: string;
  currency: string;
  layout?: 'grid' | 'list';
}

const { category, products, lang, currency, layout = 'grid' } = Astro.props;
---

{
  products.length > 0 && (
    <section
      id={`collection-${category.id}`}
      class="scroll-mt-20 py-6"
      data-category-id={category.id}
      data-menu-section
    >
      <div class="mx-auto max-w-[1160px] px-4 sm:px-6 lg:px-8">
        <h2 class="mb-5 text-2xl font-bold leading-8 text-foreground">{category.name}</h2>
        <div
          class:list={[
            layout === 'list'
              ? 'flex flex-col gap-2 sm:gap-3'
              : 'grid grid-cols-2 gap-3 lg:grid-cols-4',
          ]}
        >
          {products.map((product) => (
            <ProductCard product={product} lang={lang} currency={currency} variant={layout} />
          ))}
        </div>
      </div>
    </section>
  )
}
