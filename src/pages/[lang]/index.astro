---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import HeroSection from '@/components/astro/HeroSection.astro';
import MenuSection from '@/components/astro/MenuSection.astro';
import Footer from '@/components/astro/Footer.astro';
import SEOHead from '@/components/astro/SEOHead.astro';
import StructuredData from '@/components/astro/StructuredData.astro';
import { normalizeProduct, flattenCategories } from '@/lib/normalize';

// Interactive Preact islands
import CategoryTabs from '@/components/interactive/CategoryTabs';
import FreshnessProvider from '@/components/interactive/FreshnessProvider';

const { merchant, lang, sdk } = Astro.locals;

// Fetch categories, then products per leaf category
const categoriesResult = await sdk.GET('/api/v1/categories/');
const rawCategories = (categoriesResult.data as { results: Array<Record<string, unknown>> } | null)?.results ?? [];
const categories = flattenCategories(rawCategories);

// Fetch products per category in parallel
const categoryProducts = await Promise.all(
  categories.map(async (cat) => {
    const result = await sdk.GET('/api/v1/products/', {
      params: { query: { category: String(cat.id) } },
    });
    const raw = (result.data as { results: Array<Record<string, unknown>> } | null)?.results ?? [];
    return { category: cat, products: raw.map(normalizeProduct) };
  }),
);

// Filter out empty categories
const sections = categoryProducts.filter((s) => s.products.length > 0);
const allProducts = sections.flatMap((s) => s.products);
const productIds = allProducts.map((p) => String(p.id));
---

<BaseLayout title={merchant.name} description={merchant.seo.defaultDescription}>
  <SEOHead
    slot="head"
    page="menu"
    merchant={merchant}
    lang={lang}
    canonicalUrl={`${Astro.url.origin}/${lang}/`}
  />
  <StructuredData slot="head" type="restaurant" merchant={merchant} />

  <Header merchant={merchant} lang={lang} />
  <HeroSection merchant={merchant} />

  <CategoryTabs client:load categories={categories} />

  <main>
    {sections.map((s) => (
      <MenuSection
        category={s.category}
        products={s.products}
        lang={lang}
        currency={merchant.currency}
        layout={merchant.layout}
      />
    ))}
  </main>

  <FreshnessProvider client:idle productIds={productIds} />

  <Footer merchant={merchant} lang={lang} />
</BaseLayout>
