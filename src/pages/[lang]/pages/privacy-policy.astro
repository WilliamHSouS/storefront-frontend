---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import SEOHead from '@/components/astro/SEOHead.astro';
import type { MerchantConfig } from '@/types/merchant';
import { t } from '@/i18n';

const merchant = Astro.locals.merchant as MerchantConfig;
const lang = Astro.locals.lang as string;
---

<BaseLayout title={`${t('privacyPolicy', lang)} — ${merchant.name}`}>
  <SEOHead
    slot="head"
    page="cms"
    merchant={merchant}
    lang={lang}
    title={t('privacyPolicy', lang)}
  />
  <Header merchant={merchant} lang={lang} />

  <main class="mx-auto max-w-[1160px] px-4 py-8 sm:px-6 lg:px-8">
    <article
      class="prose prose-sm max-w-none text-foreground prose-headings:font-heading prose-headings:text-foreground prose-a:text-primary"
    >
      <h1 class="font-heading text-2xl font-bold">{t('privacyPolicy', lang)}</h1>
      <p>{t('privacyPolicyIntro', lang, { merchantName: merchant.name })}</p>

      <h2>{t('privacyDataCollected', lang)}</h2>
      <p>{t('privacyDataCollectedBody', lang)}</p>

      <h2>{t('privacyHowWeUse', lang)}</h2>
      <p>{t('privacyHowWeUseBody', lang)}</p>

      <h2>{t('privacySharing', lang)}</h2>
      <p>{t('privacySharingBody', lang)}</p>

      <h2>{t('privacyRights', lang)}</h2>
      <p>{t('privacyRightsBody', lang)}</p>

      <h2>{t('privacyContact', lang)}</h2>
      <p>
        {merchant.name}<br />
        {merchant.contact.email}<br />
        {merchant.contact.address}
      </p>
    </article>
  </main>

  <Footer merchant={merchant} lang={lang} />
</BaseLayout>
