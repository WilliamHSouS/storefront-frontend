---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import MenuSection from '@/components/astro/MenuSection.astro';
import Footer from '@/components/astro/Footer.astro';
import SEOHead from '@/components/astro/SEOHead.astro';
import StructuredData from '@/components/astro/StructuredData.astro';
import { generateBreadcrumbLD, generateItemListLD } from '@/lib/structured-data';
import { normalizeProduct, normalizeCollection, flattenCategories } from '@/lib/normalize';
import type { NormalizedCategory } from '@/lib/normalize';

const { merchant, lang, sdk } = Astro.locals;
const { slug } = Astro.params;

// Try collections first, fall back to categories
let category: NormalizedCategory | undefined;
let products: ReturnType<typeof normalizeProduct>[] = [];

// 1. Try fetching collection by slug directly (parallel)
const [collectionResult, productsResult] = await Promise.all([
  sdk.GET(`/api/v1/collections/{slug}/`, { params: { path: { slug: slug! } } }),
  sdk.GET(`/api/v1/collections/{slug}/products/`, { params: { path: { slug: slug! } } }),
]);

if (collectionResult.data) {
  category = normalizeCollection(collectionResult.data as Record<string, unknown>);
  const rawProducts =
    (productsResult.data as { results: Array<Record<string, unknown>> } | null)?.results ?? [];
  products = rawProducts.map(normalizeProduct);
} else {
  // 2. Fallback: look up slug in categories
  const categoriesResult = await sdk.GET('/api/v1/categories/');
  const rawCategories =
    (categoriesResult.data as { results: Array<Record<string, unknown>> } | null)?.results ?? [];
  const categories = flattenCategories(rawCategories);
  category = categories.find((c) => c.slug === slug);

  if (category) {
    const productsResult = await sdk.GET('/api/v1/products/', {
      params: { query: { category: String(category.id) } },
    });
    const rawProducts =
      (productsResult.data as { results: Array<Record<string, unknown>> } | null)?.results ?? [];
    products = rawProducts.map(normalizeProduct);
  }
}

if (!category) {
  return Astro.redirect(`/${lang}/`);
}

const breadcrumbs = [
  { name: merchant.name, url: `/${lang}/` },
  { name: category.name, url: `/${lang}/collection/${slug}` },
];
---

<BaseLayout title={category.name} description={`${category.name} - ${merchant.name}`}>
  <SEOHead
    slot="head"
    page="category"
    merchant={merchant}
    lang={lang}
    title={category.name}
    canonicalUrl={`${Astro.url.origin}/${lang}/collection/${slug}`}
  />
  <StructuredData slot="head" data={generateBreadcrumbLD(breadcrumbs)} />
  <StructuredData slot="head" data={generateItemListLD(category.name, products.map((p) => ({
    name: p.name,
    url: `${Astro.url.origin}/${lang}/product/${p.slug}`,
  })))} />

  <Header merchant={merchant} lang={lang} />

  <main class="py-6">
    <MenuSection
      category={category}
      products={products}
      lang={lang}
      currency={merchant.currency}
      layout={merchant.layout}
    />
  </main>

  <Footer merchant={merchant} lang={lang} />
</BaseLayout>
