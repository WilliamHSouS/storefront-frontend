---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import SEOHead from '@/components/astro/SEOHead.astro';
import StructuredData from '@/components/astro/StructuredData.astro';
import AddToCartButton from '@/components/interactive/AddToCartButton';
import ProductSuggestions from '@/components/interactive/ProductSuggestions';
import { formatPrice, langToLocale } from '@/lib/currency';
import {
  getEffectivePrice,
  getOriginalPrice,
  hasUnitDiscount,
  type PricedItem,
} from '@/lib/pricing';
import { normalizeProduct, extractIdFromSlug, parseMetadataMap, slugify } from '@/lib/normalize';
import { responsiveImage } from '@/lib/image';
import { isBot } from '@/lib/bot-detect';
import PromoBadge from '@/components/astro/PromoBadge.astro';
import { t } from '@/i18n';

const { merchant, lang, sdk } = Astro.locals;
const { slug } = Astro.params;
const locale = langToLocale(lang);
const rawSlug = slug!;
const extractedId = extractIdFromSlug(rawSlug);

async function fetchProductDetailById(id: string) {
  const { data } = await sdk.GET(`/api/v1/products/{id}/`, {
    params: { path: { id } },
  });
  return data;
}

// Primary path: encoded slug contains a reversible ID segment.
let rawDetail = await fetchProductDetailById(extractedId);

// Compatibility path: legacy plain slugs without an ID segment.
// Resolve the slug from the product list, then fetch detail by ID.
if (!rawDetail && !rawSlug.includes('--')) {
  const { data: rawList } = await sdk.GET('/api/v1/products/');
  const productList = ((rawList as Record<string, unknown>)?.results ?? []) as Array<
    Record<string, unknown>
  >;
  const matched = productList.find((item) => {
    const raw = item as Record<string, unknown>;
    const name = String(raw.title ?? raw.name ?? raw.id ?? '');
    const apiSlug = typeof raw.slug === 'string' ? raw.slug : '';
    const normalizedLegacySlug = slugify(apiSlug || name);
    return apiSlug === rawSlug || normalizedLegacySlug === rawSlug;
  });
  if (matched?.id != null) {
    rawDetail = await fetchProductDetailById(String((matched as Record<string, unknown>).id));
  }
}

if (!rawDetail) {
  return Astro.redirect(`/${lang}/`);
}

// For non-crawler requests, redirect to the menu page and let the client
// open the product modal. This gives bookmarkable URLs that still show
// the menu context. Crawlers/bots get the full standalone page for SEO.
const userAgent = Astro.request.headers.get('user-agent') ?? '';
if (!isBot(userAgent)) {
  const productId = (rawDetail as Record<string, unknown>).id;
  const productName =
    (rawDetail as Record<string, unknown>).title ??
    (rawDetail as Record<string, unknown>).name ??
    '';
  return Astro.redirect(
    `/${lang}/?product=${encodeURIComponent(String(productId))}&name=${encodeURIComponent(String(productName))}&slug=${encodeURIComponent(rawSlug)}`,
  );
}

const product = normalizeProduct(rawDetail as Record<string, unknown>);

// Extract SEO metadata from product metadata array
const metadataMap = parseMetadataMap((rawDetail as Record<string, unknown>).metadata);
const seoTitle = metadataMap.get('seo:meta_title') ?? null;
const seoDescription = metadataMap.get('seo:meta_description') ?? null;
const seoTitleIsFull =
  seoTitle !== null && merchant.name.length > 0 && seoTitle.includes(merchant.name);

const discount = (product.discount ?? null) as PricedItem['discount'];
const hasDiscount = discount !== null;
const pricedItem: PricedItem = { price: product.price, discount };
const effectivePrice = getEffectivePrice(pricedItem);
const originalPrice = getOriginalPrice(pricedItem);
const showStrikethrough = hasUnitDiscount(pricedItem);
const hasModifiers = product.modifier_groups.length > 0;
const productImgAttrs = product.image
  ? responsiveImage(product.image, [300, 450, 600, 900], '(min-width: 768px) 600px, 100vw')
  : null;

// Sort images by position for gallery display
const galleryImages = [...product.images].sort((a, b) => a.position - b.position);
const hasGallery = galleryImages.length > 1;

// Process attribute values for display in the template
interface DisplayAttribute {
  name: string;
  value: string;
}
interface RawAttribute {
  attribute_name?: string;
  input_type?: string;
  selected_choices?: Array<{ value: string; slug?: string }>;
  value_boolean?: boolean;
  value_numeric?: number | string;
  value_text?: string;
}
const displayAttributes: DisplayAttribute[] = [];
if (Array.isArray(product.attribute_values)) {
  for (const raw of product.attribute_values as RawAttribute[]) {
    let display: string | null = null;
    if (
      raw.input_type === 'multiselect' &&
      raw.selected_choices &&
      raw.selected_choices.length > 0
    ) {
      const labels = raw.selected_choices
        .map((c) => c.value || c.slug?.replace(/_/g, ' ') || '')
        .filter(Boolean);
      display = labels.length > 0 ? labels.join(', ') : null;
    } else if (raw.input_type === 'boolean' && raw.value_boolean != null) {
      display = raw.value_boolean ? t('yes', lang) : t('no', lang);
    } else if (raw.input_type === 'numeric' && raw.value_numeric != null) {
      display = String(Math.round(Number(raw.value_numeric)));
    } else if (raw.value_text) {
      display = raw.value_text;
    }
    if (display && raw.attribute_name) {
      displayAttributes.push({ name: raw.attribute_name, value: display });
    }
  }
}

// Pre-compute SEO head props to avoid non-null assertions in template
const headRawTitle = seoTitleIsFull ? seoTitle : undefined;
const headTitle = seoTitleIsFull ? undefined : (seoTitle ?? product.name);

const breadcrumbs = [
  { name: merchant.name, url: `/${lang}/` },
  { name: product.name, url: `/${lang}/product/${product.slug}` },
];
---

<BaseLayout title={product.name} description={product.description ?? ''}>
  <SEOHead
    slot="head"
    page="product"
    merchant={merchant}
    lang={lang}
    rawTitle={headRawTitle}
    title={headTitle}
    description={seoDescription ?? product.description ?? ''}
    canonicalUrl={`${Astro.url.origin}/${lang}/product/${product.slug}`}
    image={product.image ?? undefined}
  />
  <StructuredData
    slot="head"
    type="product"
    merchant={merchant}
    product={{
      name: product.name,
      price: product.price,
      description: product.description ?? undefined,
      image: product.image,
      slug: product.slug,
    }}
  />
  <StructuredData slot="head" type="breadcrumb" merchant={merchant} breadcrumbs={breadcrumbs} />

  <Header merchant={merchant} lang={lang} />

  <main class="mx-auto max-w-screen-xl px-4 py-6">
    <div class="grid gap-6 md:grid-cols-2">
      {/* Product image gallery */}
      <div>
        <div class="aspect-square overflow-hidden rounded-lg bg-card-image">
          {
            productImgAttrs ? (
              <img
                id="product-main-image"
                src={productImgAttrs.src}
                srcset={productImgAttrs.srcset}
                sizes={productImgAttrs.sizes}
                alt={product.name}
                class="h-full w-full object-cover"
                width="600"
                height="600"
                loading="eager"
                fetchpriority="high"
              />
            ) : (
              <div class="flex h-full w-full items-center justify-center text-muted-foreground/30">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="64"
                  height="64"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <>
                    <rect width="18" height="18" x="3" y="3" rx="2" ry="2" />
                    <circle cx="9" cy="9" r="2" />
                    <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
                  </>
                </svg>
              </div>
            )
          }
        </div>

        {/* Thumbnail strip */}
        {
          hasGallery && (
            <div class="mt-3 flex gap-2 overflow-x-auto scrollbar-none" id="product-thumbnails">
              {galleryImages.map((img, i) => (
                <button
                  type="button"
                  class:list={[
                    'h-16 w-16 shrink-0 overflow-hidden rounded-md border-2 transition-all',
                    i === 0
                      ? 'border-primary ring-1 ring-primary'
                      : 'border-transparent hover:border-border',
                  ]}
                  data-thumb-src={img.image_url}
                  data-thumb-alt={img.alt_text || product.name}
                >
                  <img
                    src={img.image_url}
                    alt={img.alt_text || product.name}
                    class="h-full w-full object-cover"
                    width="64"
                    height="64"
                    loading="lazy"
                  />
                </button>
              ))}
            </div>
          )
        }
      </div>

      {/* Product details */}
      <div>
        <div class="flex items-start justify-between gap-3">
          <h1 class="font-heading text-2xl font-bold text-foreground">
            {product.name}
          </h1>
          {
            hasDiscount && (
              <PromoBadge
                item={pricedItem}
                currency={merchant.currency}
                locale={locale}
                lang={lang}
              />
            )
          }
        </div>

        {/* Intro / tagline */}
        {
          product.intro && (
            <p class="mt-1 text-sm font-medium text-muted-foreground">{product.intro}</p>
          )
        }

        {product.description && <p class="mt-2 text-muted-foreground">{product.description}</p>}

        {/* Tags */}
        {
          product.tags.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-1.5">
              {product.tags.map((tag) => (
                <span class="inline-flex items-center rounded-full bg-accent px-2.5 py-0.5 text-xs font-medium text-accent-foreground">
                  {tag}
                </span>
              ))}
            </div>
          )
        }

        <div class="mt-4 flex items-baseline gap-2">
          <span class="text-xl font-bold text-foreground">
            {formatPrice(String(effectivePrice), merchant.currency, locale)}
          </span>
          {
            showStrikethrough && (
              <span class="text-base text-muted-foreground line-through">
                {formatPrice(String(originalPrice), merchant.currency, locale)}
              </span>
            )
          }
        </div>

        {/* Attributes (allergens, storage, etc.) */}
        {
          displayAttributes.length > 0 && (
            <div class="mt-4 space-y-1.5">
              {displayAttributes.map((attr) => (
                <div class="flex gap-2 text-sm">
                  <span class="font-medium text-muted-foreground">{attr.name}:</span>
                  <span class="text-foreground">{attr.value}</span>
                </div>
              ))}
            </div>
          )
        }

        <div class="mt-6">
          <AddToCartButton
            client:idle
            productId={String(product.id)}
            productName={product.name}
            hasModifiers={hasModifiers}
            soldOut={product.sold_out}
            lang={lang}
          />
        </div>

        <ProductSuggestions client:idle productId={String(product.id)} lang={lang} />

        <a
          href={`/${lang}/`}
          class="mt-4 inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg
          >
          {t('backToMenu', lang)}
        </a>
      </div>
    </div>
  </main>

  <Footer merchant={merchant} lang={lang} />
</BaseLayout>

{
  /* Image gallery thumbnail switching — safe to include always, no-ops when #product-thumbnails absent */
}
<script is:inline>
  document.getElementById('product-thumbnails')?.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-thumb-src]');
    if (!btn) return;
    const mainImg = document.getElementById('product-main-image');
    if (mainImg) {
      mainImg.src = btn.dataset.thumbSrc;
      mainImg.alt = btn.dataset.thumbAlt || '';
    }
    // Update active thumbnail ring
    btn.parentElement.querySelectorAll('button').forEach((b) => {
      b.classList.remove('border-primary', 'ring-1', 'ring-primary');
      b.classList.add('border-transparent');
    });
    btn.classList.remove('border-transparent');
    btn.classList.add('border-primary', 'ring-1', 'ring-primary');
  });
</script>
