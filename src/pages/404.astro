---
// Branded 404 page for unknown merchants.
// Does NOT use BaseLayout — no merchant context available.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Restaurant Not Found | Sous</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #fafafa;
        color: #1a1a1a;
        padding: 2rem;
        text-align: center;
      }
      h1 {
        font-size: 1.5rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
      }
      p {
        color: #666;
        max-width: 28rem;
        line-height: 1.6;
      }
      a {
        color: #1a1a1a;
        text-decoration: underline;
        text-underline-offset: 2px;
      }
      .logo {
        font-size: 0.875rem;
        color: #999;
        margin-top: 3rem;
      }
    </style>
  </head>
  <body>
    <h1>Restaurant not found</h1>
    <p>
      We couldn't find a restaurant at this address. If you believe this is an error, please contact
      the restaurant directly.
    </p>
    <div class="logo">Powered by <a href="https://poweredbysous.com?utm_source=storefront&utm_medium=footer&utm_campaign=powered_by">SOUS</a></div>
  </body>
</html>
